<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.App.ActionButton" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/bg_action_button_selector</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@color/action_button_text_color</item>
        <item name="iconTint">@color/action_button_icon_tint</item>
        <item name="rippleColor">@color/login_blue_primary</item>
    </style>

    <style name="ShapeAppearance.App.Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="BottomNavActiveIndicatorTransparent">
        <item name="android:width">0dp</item>
        <item name="android:height">0dp</item>
        <item name="marginHorizontal">0dp</item>
        <item name="android:color">@android:color/transparent</item>
    </style>

    <style name="Widget.App.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="strokeWidth">0dp</item>
        <item name="strokeColor">@android:color/transparent</item>
        <item name="cardElevation">2dp</item>
        <item name="cardCornerRadius">12dp</item>
    </style>

    <style name="Widget.App.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="android:minHeight">52dp</item>
        <item name="itemIconSize">24dp</item>
        <item name="itemPaddingTop">4dp</item>
        <item name="itemPaddingBottom">4dp</item>
    </style>
</resources>
